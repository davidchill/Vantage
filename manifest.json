{
  "manifest_version": 3,
  "name": "Vantage",
  "version": "0.2.4",
  "description": "A live performance console for Chrome — monitor tabs, extensions, memory and page health, and diagnose what's slowing your browser down.",
  "minimum_chrome_version": "121",
  "permissions": [
    "tabs",
    "tabGroups",
    "system.memory",
    "system.cpu",
    "storage",
    "alarms",
    "sidePanel",
    "management",
    "debugger",
    "cookies"
  ],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content/perf-probe.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_title": "Vantage — click to toggle panel"
  },
  "side_panel": {
    "default_path": "src/ui/panel/panel.html"
  }
}
